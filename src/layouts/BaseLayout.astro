---
import { ClientRouter } from 'astro:transitions';
import { getImage } from 'astro:assets';
import defaultHeroImage from '@media/images/homepage-hero-poster.jpg';
import { typography } from '@styles/globalStyles';

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; width: number; height: number };
  type?: string;
  path?: string;
}

const {
  title = 'Reaching Your Audience',
  description = 'BrandGlue website',
  image,
  type = 'website',
  path = '',
} = Astro.props;

const siteUrl = 'https://brandglue.com';
const siteTitle = 'BrandGlue';
const siteKeywords = 'social media, social media agency';
const canonical = `${siteUrl}${path}`;
const pageTitle = `${siteTitle} | ${title}`;

const defaultImage = await getImage({ src: defaultHeroImage, width: 1200, format: 'jpeg' });
const metaImage = image ?? {
  src: `${siteUrl}${defaultImage.src}`,
  width: defaultImage.options.width as number ?? 1200,
  height: defaultImage.options.height as number ?? 630,
};
const imageSrc = typeof metaImage.src === 'string' && metaImage.src.startsWith('http')
  ? metaImage.src
  : `${siteUrl}${metaImage.src}`;

const typographyCSS = typography.toString();
---

<!DOCTYPE html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta name="keywords" content={siteKeywords} />
    <meta name="author" content={siteTitle} />

    <!-- Open Graph -->
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={imageSrc} />
    <meta property="og:image:secure_url" content={imageSrc} />
    <meta property="og:image:width" content={String(metaImage.width)} />
    <meta property="og:image:height" content={String(metaImage.height)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content={siteTitle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <ClientRouter />

    <!-- Google Fonts (Lato) — required by Typography.js config -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <!-- Typography.js base styles -->
    <style set:html={typographyCSS}></style>

    <!-- Hide page on initial load until React hydrates with the correct layout.
         On View Transitions navigations, keep the page visible to avoid a flash.
         GlobalStyles (SC) also sets this rule but isn't SSR'd, so it arrives too late. -->
    <style>html.no-js:not(.vt-ready) { visibility: hidden; }</style>
    <script is:inline>
      document.addEventListener('astro:before-swap', (e) => {
        // Copy styled-components style tags to the incoming document so there is
        // no flash of unstyled content between the head swap and React re-hydration.
        const scStyles = [...document.head.querySelectorAll('style[data-styled]')];
        scStyles.forEach((style) => {
          e.newDocument.head.appendChild(style.cloneNode(true));
        });
        // Prevent the visibility:hidden rule from re-hiding the page on subsequent
        // navigations (the rule only applies to .no-js:not(.vt-ready)).
        e.newDocument.documentElement.classList.add('vt-ready');
      });
    </script>

    <!-- Google Analytics (production only) -->
    {import.meta.env.PROD && (
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-E3CD8VEZNZ"></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'UA-4139092-4');
        gtag('config', 'G-E3CD8VEZNZ');
      </script>
    )}

  </head>
  <body>
    <slot />
  </body>
</html>
