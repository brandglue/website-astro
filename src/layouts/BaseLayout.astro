---
import { ClientRouter } from 'astro:transitions';
import { getImage } from 'astro:assets';
import defaultHeroImage from '@media/images/homepage-hero-poster.jpg';
import { typography } from '@styles/globalStyles';

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; width: number; height: number };
  type?: string;
  path?: string;
}

const {
  title = 'Reaching Your Audience',
  description = 'BrandGlue website',
  image,
  type = 'website',
  path = '',
} = Astro.props;

const siteUrl = 'https://brandglue.com';
const siteTitle = 'BrandGlue';
const siteKeywords = 'social media, social media agency';
const canonical = `${siteUrl}${path}`;
const pageTitle = `${siteTitle} | ${title}`;

const defaultImage = await getImage({ src: defaultHeroImage, width: 1200, format: 'jpeg' });
const metaImage = image ?? {
  src: `${siteUrl}${defaultImage.src}`,
  width: defaultImage.options.width as number ?? 1200,
  height: defaultImage.options.height as number ?? 630,
};
const imageSrc = typeof metaImage.src === 'string' && metaImage.src.startsWith('http')
  ? metaImage.src
  : `${siteUrl}${metaImage.src}`;

const typographyCSS = typography.toString();
---

<!DOCTYPE html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta name="keywords" content={siteKeywords} />
    <meta name="author" content={siteTitle} />

    <!-- Open Graph -->
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={imageSrc} />
    <meta property="og:image:secure_url" content={imageSrc} />
    <meta property="og:image:width" content={String(metaImage.width)} />
    <meta property="og:image:height" content={String(metaImage.height)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content={siteTitle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <ClientRouter />

    <!-- Google Fonts (Lato) — required by Typography.js config -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <!-- Typography.js base styles -->
    <style set:html={typographyCSS}></style>

    <!-- Hide page on initial load until React hydrates with the correct layout.
         On View Transitions navigations, keep the page visible to avoid a flash.
         GlobalStyles (SC) also sets this rule but isn't SSR'd, so it arrives too late. -->
    <style>html.no-js:not(.vt-ready) { visibility: hidden; }</style>
    <!-- Hide the mobile hamburger on large screens before React hydrates.
         The SSR'd Header always renders the mobile layout (windowWidth initialises to 0),
         so without this rule the hamburger briefly flashes during View Transitions.
         data-hamburger is forwarded to the DOM by @emotion/is-prop-valid (data-* always valid).
         Must be is:global — scoped styles don't reach inside React islands. -->
    <style is:global>
      @media (min-width: 1024px) { [data-hamburger] { display: none !important; } }
    </style>
    <script is:inline>
      document.addEventListener('astro:before-swap', (e) => {
        // Snapshot all styled-components styles (works in both CSSOM/speedy mode and
        // disableCSSOMInjection mode) and inject them into the incoming document so
        // there is no flash of unstyled content between the head swap and hydration.
        const scStyleEls = [...document.head.querySelectorAll('style[data-styled]')];
        scStyleEls.forEach((styleEl) => {
          const clone = /** @type {HTMLStyleElement} */ (styleEl.cloneNode(true));
          // In production SC uses speedy/CSSOM mode: rules live in sheet.cssRules,
          // not in textContent. Serialize them so the clone carries the actual CSS.
          if (!clone.textContent?.trim() && styleEl.sheet) {
            try {
              clone.textContent = [...styleEl.sheet.cssRules]
                .map((r) => r.cssText)
                .join('\n');
            } catch (_) {}
          }
          e.newDocument.head.appendChild(clone);
        });
        // Prevent the visibility:hidden rule from re-hiding the page on subsequent
        // navigations (the rule only applies to .no-js:not(.vt-ready)).
        e.newDocument.documentElement.classList.add('vt-ready');
      });
    </script>

    <!-- Google Analytics (production only) -->
    {import.meta.env.PROD && (
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-E3CD8VEZNZ"></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'UA-4139092-4');
        gtag('config', 'G-E3CD8VEZNZ');
      </script>
    )}

  </head>
  <body>
    <!-- Static noscript banner — lives outside the React island to avoid
         React 19 omitting <noscript> from SSR output (causing hydration mismatch). -->
    <noscript>
      <style>html { visibility: visible !important; }</style>
      <div style="display:flex;justify-content:center;background:#828487;color:#fff;padding:10px;">
        This site works better with JavaScript enabled.
      </div>
    </noscript>
    <slot />
  </body>
</html>
