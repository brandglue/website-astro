---
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostRoot from '../../components/BlogPostRoot';
import { MdxLink } from '../../components/core/links/MdxLink';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Format date
const dateFormatted = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Cover image for OG
let ogImage: { src: string; width: number; height: number } | undefined;
if (post.data.cover_image) {
  const img = await getImage({ src: post.data.cover_image, width: 1200, format: 'jpeg' });
  ogImage = { src: img.src, width: 1200, height: 630 };
}

const path = `/blog/${post.data.slug}/`;
const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: post.data.title, href: path },
];

const pageUrl = `https://brandglue.com${path}`;
---

<BaseLayout
  title={post.data.title}
  description={post.body.slice(0, 160)}
  image={ogImage}
  path={path}
  type="article"
>
  <BlogPostRoot
    client:load
    post={{
      slug: post.data.slug,
      title: post.data.title,
      author: post.data.author,
      date: dateFormatted,
      categories: post.data.categories,
    }}
    crumbs={crumbs}
    pageUrl={pageUrl}
  >
    <Content components={{ a: MdxLink }} />
  </BlogPostRoot>
</BaseLayout>

